APP_NAME=ibrat-crm-api
APP_VERSION=0.0.1
NODE_ENV=staging
APP_HOST=0.0.0.0
PORT=3000
API_PREFIX=
BODY_LIMIT=1mb
TRUST_PROXY=true
BUILD_HASH=qa-local
BUILD_TIME=local

MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=ibrat_qa
MONGO_AUTO_INDEX=true

JWT_SECRET=qa_access_secret_change_me_at_least_32_chars
JWT_REFRESH_SECRET=qa_refresh_secret_change_me_at_least_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:4173,http://localhost:5173
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_NO_ORIGIN=false

RATE_LIMIT_PROVIDER=redis
REDIS_URL=redis://redis:6379
PUBLIC_RATE_LIMIT_TTL=60000
PUBLIC_RATE_LIMIT_LIMIT=30

TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=
DOMAIN=
TELEGRAM_WEBHOOK_PATH=/bot

SEED_DEFAULT_PASSWORD=ChangeMe123!
SEED_BRANCH_ID=qa-branch
