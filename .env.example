APP_NAME=panda
APP_VERSION=0.0.1
NODE_ENV=development
APP_HOST=0.0.0.0
PORT=3000
API_PREFIX=
BODY_LIMIT=1mb
TRUST_PROXY=false

# MONGO_URI is primary; MONGODB_URI is accepted as a Render-style alias.
MONGO_URI=mongodb://localhost:27017
MONGODB_URI=
MONGO_DB_NAME=ibrat_dev
MONGO_AUTO_INDEX=true

JWT_SECRET=dev_access_secret_change_me_32_chars
# JWT_REFRESH_SECRET is primary; REFRESH_JWT_SECRET is accepted as a deploy alias.
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_32_chars
REFRESH_JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_NO_ORIGIN=true

RATE_LIMIT_PROVIDER=memory
PUBLIC_RATE_LIMIT_TTL=60000
PUBLIC_RATE_LIMIT_LIMIT=20
REDIS_URL=

TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=
DOMAIN=
TELEGRAM_WEBHOOK_PATH=/bot
TELEGRAM_NOTIFICATIONS_ENABLED=true

ENABLE_SCHEDULER=false
SCHEDULE_TIMEZONE_OFFSET_MINUTES=300
SCHEDULER_DRY_RUN=false
PAYMENT_GENERATION_ENABLED=false
DEBT_AGING_ENABLED=false
DEBT_REMINDERS_ENABLED=false
PAYMENT_GENERATION_HOUR=1
DEBT_AGING_HOUR=2
DEBT_REMINDERS_HOUR=10

SMS_ENABLED=false
SMS_PROVIDER=mock
SMS_DRY_RUN=true
SMS_DEFAULT_LOCALE=ru
SMS_CENTER_NAME=Inter Talim
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=
SMS_MAX_DEBT_REMINDERS_PER_DAY=3
