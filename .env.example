APP_NAME=panda
APP_VERSION=0.0.1
NODE_ENV=production
APP_HOST=0.0.0.0
PORT=3000
API_PREFIX=
API_ENABLE_VERSIONING=false
API_DEFAULT_VERSION=1
BODY_LIMIT=1mb
TRUST_PROXY=true
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/ibrat
MONGO_DB_NAME=
MONGO_MIN_POOL_SIZE=1
MONGO_MAX_POOL_SIZE=10
MONGO_AUTO_INDEX=false
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_refresh_secret
REFRESH_TOKEN_EXPIRES_IN=7d
TENANT_MODE=single-database
TENANT_KEY_HEADER=x-tenant-id
BRANCH_KEY_HEADER=x-branch-id
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=
DOMAIN=https://api.example.com
TELEGRAM_WEBHOOK_PATH=/bot
CORS_ORIGINS=https://app.example.com,https://www.app.example.com
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_NO_ORIGIN=true
